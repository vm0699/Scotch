# ── Scotch environment configuration ──────────────────────────────
# Copy to .env and fill in as needed. Deterministic generation works
# with no keys configured.

# Backend (services/api)
SCOTCH_API_PORT=8000

# AI providers (optional until Phase 9)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Frontend (apps/web) — base URL of the Scotch backend
NEXT_PUBLIC_API_URL=http://localhost:8000
