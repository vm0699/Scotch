# ── Scotch environment configuration ──────────────────────────────
# Copy to .env and fill in as needed. Deterministic generation works
# with no keys configured.

# Backend (services/api)
SCOTCH_API_PORT=8000

# Generation mode: deterministic (default) | ai | hybrid
SCOTCH_GENERATION_MODE=deterministic

# AI providers (Phase 9) — add a key to unlock AI generation mode.
# Keys are read server-side only; never exposed to the browser.
SCOTCH_ANTHROPIC_API_KEY=
SCOTCH_ANTHROPIC_MODEL=claude-sonnet-4-6

SCOTCH_OPENAI_API_KEY=
SCOTCH_OPENAI_BASE_URL=https://api.openai.com/v1
SCOTCH_OPENAI_MODEL=gpt-4o

# Frontend (apps/web) — base URL of the Scotch backend
NEXT_PUBLIC_API_URL=http://localhost:8000
